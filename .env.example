# Env vars consumed by waf-bots. Copy to `.env` (gitignored) and fill in.
# Real values live in the operator's Obsidian vault lockbox `02_Areas/_secrets/antibot.md`.

# ---- BOT-2 ATO ----
# Visitor account for repeated login attempts. If unset, BOT cycles through
# fake usernames (waf-test-NNNNNN@example.invalid) which still trigger
# ATO detection on enough volume.
WAF_BOTS_ATO_USERNAME=
WAF_BOTS_ATO_PASSWORD=

# ---- BOT-1 DoS safety gate ----
# Set to literal "true" (case-insensitive) to allow BOT-1 to run with
# --no-dry-run. Otherwise BOT-1 setup() raises and refuses to start.
# DO NOT set this in CI or shared dev shells. Only on the run host.
WAF_BOTS_ALLOW_DOS=

# ---- Generic ----
# Override the default base URL https://api-coll.museiitaliani.it.
# Empty / unset = use the default.
API_BASE_URL_OVERRIDE=
