        <task id="1" name="Discovery e design" color="#2e7d32" meeting="false" start="2026-04-27" duration="2" complete="0" expand="true">
            <notes><![CDATA[Lettura specifica, Excel endpoint, swagger collaudo. Decisioni architetturali (Linode fleet vs locale, dry-run safety, branching).]]></notes>
            <depend id="2" type="2" difference="0" hardness="Strong"/>
            <depend id="3" type="2" difference="0" hardness="Strong"/>
        </task>
        <task id="2" name="Apertura ticket PSN whitelist WAF" color="#c62828" meeting="false" start="2026-04-29" duration="1" complete="0" expand="true">
            <notes><![CDATA[Ticket PSN con domanda semantica whitelist (admit-only vs admit+bypass antiBot) e IP fleet. Aperto subito dopo discovery in modo che la wait corra in parallelo.]]></notes>
            <depend id="4" type="2" difference="0" hardness="Strong"/>
        </task>
        <task id="4" name="Wait PSN + whitelist applicata" color="#c62828" meeting="false" start="2026-04-30" duration="2" complete="0" expand="true">
            <notes><![CDATA[Attesa risposta PSN + applicazione whitelist sui 5 IP del fleet. Non sul critical path se il dev stream finisce dopo.]]></notes>
            <depend id="9" type="2" difference="0" hardness="Strong"/>
        </task>
        <task id="3" name="Build core framework" color="#1565c0" meeting="false" start="2026-04-29" duration="3" complete="0" expand="true">
            <notes><![CDATA[Repo, scaffolding Python (uv + ruff + mypy), Dockerfile, CI GitHub Actions, runner generico, WAF signals classifier, reporter Markdown.]]></notes>
            <depend id="5" type="2" difference="0" hardness="Strong"/>
            <depend id="6" type="2" difference="0" hardness="Strong"/>
        </task>
        <task id="5" name="Implementazione BOT" color="#1565c0" meeting="false" start="2026-05-04" duration="4" complete="0" expand="true">
            <notes><![CDATA[3 stream paralleli sopra il core framework.]]></notes>
            <task id="5a" name="HTTP (BOT-1 DoS + BOT-2 ATO)" color="#1976d2" meeting="false" start="2026-05-04" duration="3" complete="0" expand="true">
                <notes><![CDATA[httpx async, dry-run safe, BOT-1 con env safety WAF_BOTS_ALLOW_DOS.]]></notes>
            </task>
            <task id="5b" name="Browser (BOT-4 Content + BOT-5 Price)" color="#1976d2" meeting="false" start="2026-05-04" duration="4" complete="0" expand="true">
                <notes><![CDATA[Playwright Chromium headless, navigator.webdriver=true di default (no stealth).]]></notes>
            </task>
            <task id="5c" name="Admin API (BOT-3 Registration)" color="#1976d2" meeting="false" start="2026-05-04" duration="3" complete="0" expand="true">
                <notes><![CDATA[Keycloak realm AD-Arte-visitors, password grant + POST /admin/realms/.../users, refresh token su 401.]]></notes>
            </task>
            <depend id="9" type="2" difference="0" hardness="Strong"/>
        </task>
        <task id="6" name="Infrastruttura e credenziali" color="#ef6c00" meeting="false" start="2026-05-04" duration="2" complete="0" expand="true">
            <notes><![CDATA[Stream parallelo: estrazione cred Keycloak da K8s collaudo + provisioning fleet Linode 5 VM in nl-ams (2x g6-standard-1 + 3x g6-standard-2).]]></notes>
            <task id="6a" name="Estrazione credenziali collaudo" color="#fb8c00" meeting="false" start="2026-05-04" duration="1" complete="0" expand="true"/>
            <task id="6b" name="Provisioning Linode fleet" color="#fb8c00" meeting="false" start="2026-05-05" duration="2" complete="0" expand="true">
                <notes><![CDATA[SSH key + StackScript LF + 5 VM. Build immagine Docker su ciascuna VM via git clone (repo pubblico).]]></notes>
            </task>
            <depend id="9" type="2" difference="0" hardness="Strong"/>
        </task>
        <task id="9" name="Esecuzione test" color="#6a1b9a" meeting="false" start="2026-05-08" duration="1" complete="0" expand="true">
            <notes><![CDATA[Run BOT-2/3/4/5 (low risk first) + BOT-1 con pre-mortem firmato, ramp graduale concorrenza.]]></notes>
            <depend id="10" type="2" difference="0" hardness="Strong"/>
        </task>
        <task id="10" name="Report e delivery" color="#455a64" meeting="false" start="2026-05-11" duration="2" complete="0" expand="true">
            <notes><![CDATA[Consolidamento JSON->Markdown, integrazione log FortiGate forniti dal SOC, delivery cliente, teardown fleet.]]></notes>
        </task>
    </tasks>
